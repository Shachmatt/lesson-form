        function addVipCompany(button) {
            const container = button.parentElement.querySelector('.vip-companies-container');
            container.insertAdjacentHTML('beforeend', vipCompanyHtml());
        }

        // Collect all VIP data (global params, multiples, companies) from one exercise element
        function collectVipData(exerciseElement) {
            const vipBlock = exerciseElement.querySelector('[data-field="appData"]');
            if (!vipBlock) return null;

            const num = (el) => {
                if (!el || el.value === '') return null;
                const n = parseFloat(el.value);
                return isNaN(n) ? null : n;
            };

            // Global params
            const globals = {};
            vipBlock.querySelectorAll('[data-vip]').forEach(el => {
                globals[el.dataset.vip] = num(el);
            });

            // Industry multiples
            const industryMultiples = [];
            vipBlock.querySelectorAll('.vip-multiple').forEach(row => {
                const sector = row.querySelector('[data-vip-mul="sector"]').value.trim();
                const low    = num(row.querySelector('[data-vip-mul="low"]'));
                const high   = num(row.querySelector('[data-vip-mul="high"]'));
                if (sector) industryMultiples.push({ sector, low, high });
            });

            // Companies
            const companies = [];
            vipBlock.querySelectorAll('.vip-company').forEach(card => {
                const get = (key) => card.querySelector(`[data-vip-co="${key}"]`);
                const parseList = (key) => {
                    const raw = get(key) ? get(key).value : '';
                    return raw.split(',').map(s => parseFloat(s.trim())).filter(n => !isNaN(n));
                };
                companies.push({
                    name:        get('name')        ? get('name').value.trim()        : '',
                    color:       get('color')       ? get('color').value.trim()       : '',
                    description: get('description') ? get('description').value.trim() : '',
                    type:        get('type')        ? parseInt(get('type').value, 10) : null,
                    stockNum:    num(get('stockNum')),
                    FCF:         parseList('FCF'),
                    FCFPast:     parseList('FCFPast'),
                    YoY:         num(get('YoY')),
                    growth:      num(get('growth')),
                    assets:      num(get('assets')),
                    debts:       num(get('debts')),
                    EBITDA:      num(get('EBITDA')),
                    field:       num(get('field')),
                    cash:        num(get('cash')),
                    dividend:    num(get('dividend')),
                    divGrowth:   num(get('divGrowth')),
                    startPrice:  num(get('startPrice')),
                    lt:          Math.random(),
                    lQr:         Math.random(),
                    ltH:         Math.random(),
                    lQrH:        Math.random()
                });
            });

            return { ...globals, industryMultiples, companies };
        }

        // === INITIALIZE EXERCISE TYPE === 
        function initializeExerciseType(exerciseId, type) {
            const exerciseElement = document.getElementById(exerciseId);
            
            if (type === 'Question') {
                // Set name attribute for radio buttons
                const radioButtons = exerciseElement.querySelectorAll('input[type="radio"]');
                radioButtons.forEach(radio => {
                    radio.name = `correct_option_${exerciseId}`;
                });
            } else if (type === 'MultiChoice') {
                const checkBoxes = exerciseElement.querySelectorAll('input[type="checkbox"]');
                checkBoxes.forEach(box => {
                    box.name= `correct_option_${exerciseId}`
                })
            }
        }

        // === ADD OPTION FUNCTION === 
        function addOption(button, type) {
            const container = button.previousElementSibling;
            const optionCount = container.children.length;
            
            let optionHtml = '';
            
            switch(type) {
                case 'single':
                    optionHtml = `
                        <div class="option-item">
                            <input type="radio" name="correct_option" value="${optionCount}">
                            <input type="text" placeholder="Možnost ${optionCount + 1}" data-option="${optionCount}">
                            <button type="button" class="btn btn-danger" onclick="removeOption(this)">❌</button>
                        </div>
                    `;
                    break;
            }
            
            container.insertAdjacentHTML('beforeend', optionHtml);
            
            // Update radio button names for single choice
            if (type === 'single') {
                const exerciseElement = button.closest('.exercise-item');
                const radioButtons = exerciseElement.querySelectorAll('input[type="radio"]');
                radioButtons.forEach(radio => {
                    radio.name = `correct_option_${exerciseElement.id}`;
                });
            }
        }

        // === REMOVE OPTION FUNCTION === 
        function removeOption(button) {
            const optionItem = button.closest('.option-item');
            const container = optionItem.parentElement;
            
            // Don't allow removing if only 2 options remain
            if (container.children.length <= 2) {
                alert('Musí zůstat alespoň 2 možnosti!');
                return;
            }
            
            optionItem.remove();
            
            // Update option indices and labels
            const options = container.querySelectorAll('.option-item');
            options.forEach((option, index) => {
                const input = option.querySelector('input[data-option]');
                if (input) {
                    input.setAttribute('data-option', index);
                    input.placeholder = "Možnost " + (index + 1);
                }
                
                // Update radio button values
                const radio = option.querySelector('input[type="radio"]');
                if (radio) {
                    radio.value = index;
                }
            });
        }

        // === REMOVE EXERCISE FUNCTION === 
        function removeExercise(exerciseId) {
            if (confirm('Opravdu chcete odstranit toto cvičení?')) {
                document.getElementById(exerciseId).remove();
                exercises = exercises.filter(ex => ex.id !== exerciseId);
            }
        }



        
        // === EXPORT JSON FUNCTION === 
        function exportJSON() {
            const lesson = {
                title: document.getElementById('lessonTitle').value,
                intro: document.getElementById('lessonIntro').value,
                summary: document.getElementById('summary').value,
                beforeExercise: document.getElementById('beforeExercise').value,
                outro: document.getElementById('outro').value,
                exercises: []
            };

            
            // Process each exercise
            exercises.forEach(exerciseRef => {
                const exerciseElement = document.getElementById(exerciseRef.id);
                if (!exerciseElement) return;

                const exercise = {
                    type: exerciseRef.type,
                    question: getFieldValue(exerciseElement, 'question'),
                    feedback: getFieldValue(exerciseElement, 'feedback')
                };

                // Add type-specific fields
                switch(exerciseRef.type) {
                    case 'Question':
                        const singleOptions = getOptionsFromExercise(exerciseElement);
                        exercise.options = singleOptions.options;
                        exercise.correct_index = singleOptions.correct_index;
                        break;
                    case 'MultiChoice': 
                        const multiOptions = getOptionsFromMultichoice(exerciseElement);
                        exercise.options = multiOptions.options;
                        exercise.correct = multiOptions.correct;
                        break;

                    case 'MatchExcercise':
                        const matchData = getMatchData(exerciseElement);
                        exercise.options = matchData.options;
                        exercise.labels = matchData.labels;
                        break;

                    case 'Game':
                        exercise.optionOneName = getFieldValue(exerciseElement, 'optionOneName');
                        exercise.optionTwoName = getFieldValue(exerciseElement, 'optionTwoName');
                        exercise.optionOneItems = getFieldValue(exerciseElement, 'optionOneItems').split(',').map(s => s.trim()).filter(Boolean);
                        exercise.optionTwoItems = getFieldValue(exerciseElement, 'optionTwoItems').split(',').map(s => s.trim()).filter(Boolean);
                        break;

                    case 'Calc':
                        exercise.correct = getFieldValue(exerciseElement, 'correct');
                        exercise.typeResult = getFieldValue(exerciseElement, 'typeResult');
                        break;
                    
                    case 'Info':
                        exercise.title = getFieldValue(exerciseElement, 'title');
                        exercise.content = getFieldValue(exerciseElement, 'content');
                        exercise.icon = getFieldValue(exerciseElement, 'icon');
                        delete exercise.question;
                        break;
                    case 'Conversation':
                        const conversationData = getConversationData(exerciseElement);
                        exercise.people = conversationData.people;
                        exercise.messages = conversationData.messages;
                        break;
                    case 'VIP':
                        exercise.appData = collectVipData(exerciseElement);
                        delete exercise.question;
                        delete exercise.feedback;
                        break;
                }

                lesson.exercises.push(exercise);
            });

            // Validate basic fields
            if (!lesson.title.trim()) {
                alert('Prosím vyplňte název lekce!');
                return;
            }

            if (lesson.exercises.length === 0) {
                alert('Prosím přidejte alespoň jedno cvičení!');
                return;
            }



        }

        // === HELPER FUNCTIONS === 
        function getFieldValue(exerciseElement, fieldName, type = 'text') {
            const element = exerciseElement.querySelector(`[data-field="${fieldName}"]`);
            if (!element) return '';
            
            if (type === 'checkbox') {
                return element.checked;
            }
            
            return element.value.trim();
        }

        function getOptionsFromExercise(exerciseElement) {
            const optionInputs = exerciseElement.querySelectorAll('input[data-option]');
            const options = [];
            let correct_index = -1;
            
            optionInputs.forEach((input, index) => {
                const value = input.value.trim();
                if (value) {
                    options.push(value);
                    
                    const radio = input.parentElement.querySelector('input[type="radio"]');
                    if (radio && radio.checked) {
                        correct_index = index;
                    }
                }
            });
            
            return {
                options: options,
                correct_index: correct_index
            };
        }

        function getOptionsFromMultichoice(exerciseElement) {
            const optionInputs = exerciseElement.querySelectorAll('input[data-option]');
            const options = [];
            const correct = [];

            optionInputs.forEach((input, index) => {
                const value = input.value.trim();
                if (value) {
                    options.push(value);

                    const checkbox = input.parentElement.querySelector('input[type="checkbox"]');
                    if (checkbox && checkbox.checked) {
                        correct.push(value); // store text, not index
                    }
                }
            });

            return {
                options: options,
                correct: correct
            };
        }


        function getMatchData(exerciseElement) {
            const optionsRaw = getFieldValue(exerciseElement, 'options');
            const labelsRaw = getFieldValue(exerciseElement, 'labels');
            const options = optionsRaw ? optionsRaw.split(',').map(s => s.trim()).filter(Boolean) : [];
            const labels = labelsRaw ? labelsRaw.split(',').map(s => s.trim()).filter(Boolean) : [];
            return {
                options,
                labels
            };
        }

        function getConversationData(exerciseElement) {
            const peopleRaw = getFieldValue(exerciseElement, 'people');
            const messagesRaw = getFieldValue(exerciseElement, 'messages');
            const people = peopleRaw ? peopleRaw.split(',').map(s => s.trim()).filter(Boolean) : [];
            const messages = messagesRaw ? messagesRaw.split(',').map(s => s.trim()).filter(Boolean) : [];
            return {
                people,
                messages
            };
        }




document.getElementById("lessonForm").addEventListener("submit", function (e) {
    // Zavolá exportJSON(), který sestaví JSON
    const lesson = {
        title: document.getElementById('lessonTitle').value,
        intro: document.getElementById('lessonIntro').value,
        summary: document.getElementById('summary').value,
        beforeExercise: document.getElementById('beforeExercise').value,
        outro: document.getElementById('outro').value,
        sectionId: document.getElementById('sectionId').value || null,
        exercises: []
    };

    exercises.forEach(exerciseRef => {
        const exerciseElement = document.getElementById(exerciseRef.id);
        if (!exerciseElement) return;

        const exercise = {
            type: exerciseRef.type,
            question: getFieldValue(exerciseElement, 'question'),
            feedback: getFieldValue(exerciseElement, 'feedback')

        };

        switch(exerciseRef.type) {
            case 'Question':
                const singleOptions = getOptionsFromExercise(exerciseElement);
                exercise.options = singleOptions.options;
                exercise.correct_index = singleOptions.correct_index;
                break;
            case 'MultiChoice': 
                const multiOptions = getOptionsFromMultichoice(exerciseElement);
                exercise.options = multiOptions.options;
                exercise.correct = multiOptions.correct;
                break;
            case 'MatchExcercise':
                const matchData = getMatchData(exerciseElement);
                exercise.options = matchData.options;
                exercise.labels = matchData.labels;
                break;
            case 'Game':
                exercise.optionOneName = getFieldValue(exerciseElement, 'optionOneName');
                exercise.optionTwoName = getFieldValue(exerciseElement, 'optionTwoName');
                exercise.optionOneItems = getFieldValue(exerciseElement, 'optionOneItems').split(',').map(s => s.trim()).filter(Boolean);
                exercise.optionTwoItems = getFieldValue(exerciseElement, 'optionTwoItems').split(',').map(s => s.trim()).filter(Boolean);
                break;
            case 'Calc':
                exercise.correct = getFieldValue(exerciseElement, 'correct');
                exercise.typeResult = getFieldValue(exerciseElement, 'typeResult');
                break;
            case 'Info':
                exercise.title = getFieldValue(exerciseElement, 'title');
                exercise.content = getFieldValue(exerciseElement, 'content');
                exercise.icon = getFieldValue(exerciseElement, 'icon');
                delete exercise.question;
                delete exercise.feedback;
                break;
            case 'Conversation':
                const conversationData = getConversationData(exerciseElement);
                exercise.people = conversationData.people;
                exercise.messages = conversationData.messages;
                break;
            case 'VIP':
                exercise.appData = collectVipData(exerciseElement);
                delete exercise.question;
                delete exercise.feedback;
                break;
        }

        lesson.exercises.push(exercise);
    });

    if (!lesson.title.trim() || lesson.exercises.length === 0) {
        alert("Prosím vyplňte název lekce a přidejte alespoň jedno cvičení.");
        e.preventDefault(); // Zastaví odeslání
        return;
    }

    document.getElementById("jsonData").value = JSON.stringify(lesson);
});







